# nuxt-auth-utils session cookie encryption (32+ char random string)
# Generate: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# GitHub OAuth App credentials
# Create at: https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# Postgres (Neon, Supabase pooler, or local)
DATABASE_URL=

# Public site URL — used for OAuth redirects + emails
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Bootstrap admin logins (comma-separated GitHub usernames).
# Matched users are CREATED as role='admin' on their first OAuth sign-in.
# This only affects the initial row — once a user exists, the DB is the
# source of truth and this env is ignored (so demotions stick).
# Leave empty in production unless you actually want a new env-driven
# admin to land on next first-sign-in.
NUXT_INITIAL_ADMIN_LOGINS=
